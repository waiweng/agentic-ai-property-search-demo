{
  "name": "agentic-property-search-backend",
  "version": "1.0.0",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "node --max-old-space-size=8192 node_modules/typescript/bin/tsc",
    "start": "node dist/src/index.js",
    "inject:pois": "ts-node scripts/inject-pois.ts",
    "inject:market": "ts-node scripts/inject-market-data.ts",
    "inject:properties": "ts-node scripts/inject-properties.ts",
    "inject:all": "npm run inject:pois && npm run inject:market && npm run inject:properties",
    "inject:james-ruse": "ts-node scripts/inject-properties-james-ruse.ts",
    "update:james-ruse-location": "ts-node scripts/update-james-ruse-location.ts",
    "delete:james-ruse-outliers": "ts-node scripts/delete-james-ruse-outliers.ts",
    "inject:carlingford": "ts-node scripts/inject-properties-carlingford.ts",
    "seed:properties": "ts-node scripts/seed-properties-collection.ts",
    "seed:from-json": "ts-node scripts/seed-from-json.ts",
    "test:search": "ts-node scripts/test-search.ts",
    "insert:one-carlingford": "ts-node scripts/insert-one-carlingford.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/google-vertexai": "^0.1.0",
    "@langchain/langgraph": "^0.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^9.0.0",
    "mongodb": "^6.3.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/uuid": "^9.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
