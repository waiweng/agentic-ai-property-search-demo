# MongoDB Atlas
MONGODB_ATLAS_URI=mongodb+srv://user:password@cluster.mongodb.net/

# Voyage AI (embeddings + reranker)
VOYAGE_API_KEY=your-voyage-api-key

# Vertex AI (ADC - no key needed when using gcloud auth application-default login)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project
VERTEX_AI_LOCATION=australia-southeast1
# Optional: service account impersonation
# GOOGLE_IMPERSONATION_SERVICE_ACCOUNT=sa@project.iam.gserviceaccount.com

# Server
PORT=4000
